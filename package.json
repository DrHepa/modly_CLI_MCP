{
  "name": "modly-cli-mcp",
  "version": "0.1.1",
  "description": "Installable Modly CLI and MCP server package for stdio-based consumers.",
  "author": "DrHepa",
  "homepage": "https://github.com/DrHepa/modly_CLI_MCP#readme",
  "bugs": {
    "url": "https://github.com/DrHepa/modly_CLI_MCP/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DrHepa/modly_CLI_MCP.git"
  },
  "type": "module",
  "bin": {
    "modly": "src/cli/index.mjs",
    "modly-mcp": "src/mcp/server.mjs"
  },
  "files": [
    "src/**",
    "skills/**",
    "README.md",
    "LICENSE",
    "docs/assets/**",
    "docs/install/**",
    "docs/specs/**",
    "templates/opencode/**",
    "templates/codex/**"
  ],
  "scripts": {
    "cli": "node ./src/cli/index.mjs",
    "start:cli": "node ./src/cli/index.mjs",
    "mcp": "node ./src/mcp/server.mjs",
    "start:mcp": "node ./src/mcp/server.mjs",
    "test": "node --test",
    "test:cli": "node --test test/cli/*.test.mjs",
    "test:core": "node --test test/core/*.test.mjs",
    "test:mcp": "node --test test/mcp/*.test.mjs",
    "test:packaging": "node --test test/packaging/*.test.mjs",
    "coverage": "c8 --reporter=text --reporter=lcov --include=src/**/*.mjs --exclude=test/** node --test",
    "lint": "eslint . --ext .mjs",
    "type-check": "tsc --project tsconfig.json"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "modly",
    "cli",
    "mcp",
    "opencode",
    "codex"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "c8": "^10.1.3",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3"
  }
}
